@page "/"
@using YarnInventoryWeb.Models
@using MiniExcelLibs
@using System.Net.Http.Headers
@using System.Text.Json
@inject IJSRuntime JSRuntime
@inject HttpClient Http

<PageTitle>Yarn Inventory Dashboard</PageTitle>

<div class="app-container">
    <header class="app-header">
        <div class="brand-title">
            <h2>Yarn Hub</h2>
            <span class="sync-badge @(_isSyncing ? "syncing" : (_syncFailed ? "failed" : "synced"))">
                @_syncStatus
            </span>
        </div>

        <div class="action-bar">
            <div class="history-controls">
                <button class="btn btn-icon" @onclick="ExecuteUndo" disabled="@(!_undoStack.Any())" title="Undo">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 7v6h6M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13" /></svg>
                </button>
                <button class="btn btn-icon" @onclick="ExecuteRedo" disabled="@(!_redoStack.Any())" title="Redo">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 7v6h-6M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7" /></svg>
                </button>
            </div>

            <div class="file-utilities">
                @if (string.IsNullOrWhiteSpace(_githubToken))
                {
                    <button class="btn btn-setup" @onclick="ToggleTokenModal">🔑 Link Cloud</button>
                }
                else
                {
                    <button class="btn btn-setup connected" @onclick="ToggleTokenModal">⚙️ Cloud Connected</button>
                }
                <label class="btn btn-import" for="excelFile">Import Excel</label>
                <InputFile id="excelFile" OnChange="HandleExcelImport" accept=".xlsx" style="display:none;" />
            </div>
        </div>
    </header>

    <nav class="segmented-tabs">
        <button class="tab-item @(ActiveTab == InventoryTab.Active ? "active" : "")" @onclick="() => SwitchTab(InventoryTab.Active)">
            Active Inventory <span class="count-pill">@_items.Count(i => !i.IsDiscontinued)</span>
        </button>
        <button class="tab-item @(ActiveTab == InventoryTab.Discontinued ? "active" : "")" @onclick="() => SwitchTab(InventoryTab.Discontinued)">
            Discontinued <span class="count-pill badge-warn">@_items.Count(i => i.IsDiscontinued)</span>
        </button>
    </nav>

    <div class="search-container">
        <div class="search-input-wrapper">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text"
                   class="search-box-input"
                   placeholder="Search by color code, type, or brand..."
                   @bind="_searchQuery"
                   @bind:event="oninput" />
            @if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                <button class="clear-search-trigger" @onclick="ClearSearch">✕</button>
            }
        </div>
    </div>

    <main class="list-viewport">
        @if (!FilteredItems.Any())
        {
            <div class="empty-state-card">
                <div class="empty-icon">📦</div>
                <h3>Your inventory is pristine</h3>
                <p>Import your starting spreadsheet or add items to see them tracked live.</p>
            </div>
        }
        else
        {
            @foreach (var item in FilteredItems)
            {
                <div class="inventory-card" key="@item.Id">
                    <div class="card-meta">
                        <span class="item-brand-tag">@item.Brand</span>
                        <h3 class="item-title">@item.Title</h3>
                    </div>

                    <div class="card-metrics-grid">
                        <div class="metric-control-box">
                            <span class="metric-label">In Stock</span>
                            <div class="stepper-engine">
                                <button class="step-trigger minus" @onclick="() => AdjustCount(item, i => { if (i.InStock > 0) i.InStock--; })">−</button>
                                <span class="step-display-value">@item.InStock</span>
                                <button class="step-trigger plus" @onclick="() => AdjustCount(item, i => i.InStock++)">+</button>
                            </div>
                        </div>

                        <div class="metric-control-box">
                            <span class="metric-label">Project Bag</span>
                            <div class="stepper-engine">
                                <button class="step-trigger minus" @onclick="() => AdjustCount(item, i => { if (i.InBag > 0) i.InBag--; })">−</button>
                                <span class="step-display-value">@item.InBag</span>
                                <button class="step-trigger plus" @onclick="() => AdjustCount(item, i => i.InBag++)">+</button>
                            </div>
                        </div>
                    </div>

                    <footer class="card-footer-actions">
                        <button class="btn-card-action @(item.IsDiscontinued ? "action-revive" : "action-archive")" @onclick="() => RequestTabTransition(item)">
                            @(item.IsDiscontinued ? "📦 Move to Active Assets" : "⚠️ Tag as Discontinued Product")
                        </button>
                    </footer>
                </div>
            }
        }
    </main>
</div>

@if (_showTokenModal)
{
    <div class="modal-backdrop">
        <div class="modal-card">
            <h3>Cloud Sync Configuration</h3>
            <p class="modal-instruction">Enter your GitHub credentials to seamlessly sync changes automatically across your phone and PC.</p>

            <div class="input-field-group">
                <label>GitHub Username</label>
                <input type="text" class="text-input" @bind="_githubUser" placeholder="e.g., Ledz3p" />
            </div>

            <div class="input-field-group">
                <label>Repository Name</label>
                <input type="text" class="text-input" @bind="_githubRepo" placeholder="e.g., ledz3p.github.io" />
            </div>

            <div class="input-field-group">
                <label>Personal Access Token (Classic)</label>
                <input type="password" class="text-input" @bind="_githubToken" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" />
            </div>

            <div class="modal-buttons">
                <button class="btn btn-secondary" @onclick="ToggleTokenModal">Close</button>
                <button class="btn btn-primary-accent" @onclick="SaveTokenConfiguration">Save & Initialize Cloud</button>
            </div>
        </div>
    </div>
}

@if (_pendingTransitionItem != null)
{
    <div class="modal-backdrop">
        <div class="modal-card warning-accent">
            <h3>Confirm Status Shift</h3>
            <p>Are you sure you want to transfer <strong>@_pendingTransitionItem.Brand @_pendingTransitionItem.Title</strong> to the <strong>@(_pendingTransitionItem.IsDiscontinued ? "Active Inventory" : "Discontinued")</strong> category?</p>
            <div class="modal-buttons">
                <button class="btn btn-secondary" @onclick="CancelTabTransition">Cancel</button>
                <button class="btn btn-danger-accent" @onclick="ConfirmTabTransition">Confirm Relocation</button>
            </div>
        </div>
    </div>
}

@code {
    private enum InventoryTab { Active, Discontinued }
    private InventoryTab ActiveTab { get; set; } = InventoryTab.Active;

    private List<YarnItem> _items = new();
    private Stack<HistorySnapshot> _undoStack = new();
    private Stack<HistorySnapshot> _redoStack = new();
    private YarnItem? _pendingTransitionItem;

    // Cloud Configuration state variables
    private string _githubUser = "Ledz3p";
    private string _githubRepo = "ledz3p.github.io";
    private string _githubToken = "";
    private string _currentSha = "";

    private bool _showTokenModal = false;
    private bool _isSyncing = false;
    private bool _syncFailed = false;
    private string _syncStatus = "Local Storage";

    //search
    private string _searchQuery = string.Empty;
    private void ClearSearch()
    {
        _searchQuery = string.Empty;
    }

    private IEnumerable<YarnItem> FilteredItems
    {
        get
        {
            // First split items by tab status
            var baseList = ActiveTab == InventoryTab.Active
                ? _items.Where(i => !i.IsDiscontinued)
                : _items.Where(i => i.IsDiscontinued);

            // If there's a search term, apply the text match overlay
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var query = _searchQuery.Trim().ToLower(); // Custom clear lookup string
                return baseList.Where(i =>
                    (i.Title != null && i.Title.ToLower().Contains(_searchQuery.ToLower().Trim())) ||
                    (i.Brand != null && i.Brand.ToLower().Contains(_searchQuery.ToLower().Trim()))
                );
            }

            return baseList;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCredentials();
        await LoadStateFromStorage();
        if (!string.IsNullOrWhiteSpace(_githubToken))
        {
            await PullStateFromGitHub();
        }
    }

    private void SwitchTab(InventoryTab targetTab) => ActiveTab = targetTab;
    private void ToggleTokenModal() => _showTokenModal = !_showTokenModal;
    private void CancelTabTransition() => _pendingTransitionItem = null;

    private void CaptureSnapshot()
    {
        _undoStack.Push(new HistorySnapshot(_items));
        _redoStack.Clear();
    }

    private async Task AdjustCount(YarnItem item, Action<YarnItem> mutation)
    {
        CaptureSnapshot();
        mutation(item);
        await SaveAndSync();
    }

    private void RequestTabTransition(YarnItem item) => _pendingTransitionItem = item;

    private async Task ConfirmTabTransition()
    {
        if (_pendingTransitionItem != null)
        {
            CaptureSnapshot();
            _pendingTransitionItem.IsDiscontinued = !_pendingTransitionItem.IsDiscontinued;
            _pendingTransitionItem = null;
            await SaveAndSync();
        }
    }

    private async Task ExecuteUndo()
    {
        if (_undoStack.Any())
        {
            _redoStack.Push(new HistorySnapshot(_items));
            _items = _undoStack.Pop().Items;
            await SaveAndSync();
        }
    }

    private async Task ExecuteRedo()
    {
        if (_redoStack.Any())
        {
            _undoStack.Push(new HistorySnapshot(_items));
            _items = _redoStack.Pop().Items;
            await SaveAndSync();
        }
    }

    private async Task SaveAndSync()
    {
        await SaveStateToStorage();
        await PushStateToGitHub();
    }

    private async Task SaveStateToStorage()
    {
        var serializedData = JsonSerializer.Serialize(_items);
        await JSRuntime.InvokeVoidAsync("window.localStorageFunctions.saveValue", "yarn_inventory_data", serializedData);
    }

    private async Task LoadStateFromStorage()
    {
        try
        {
            var rawData = await JSRuntime.InvokeAsync<string?>("window.localStorageFunctions.getValue", "yarn_inventory_data");
            if (!string.IsNullOrWhiteSpace(rawData))
            {
                _items = JsonSerializer.Deserialize<List<YarnItem>>(rawData) ?? new();
            }
        }
        catch { }
    }

    private async Task SaveCredentials()
    {
        await JSRuntime.InvokeVoidAsync("window.localStorageFunctions.saveValue", "gh_user", _githubUser);
        await JSRuntime.InvokeVoidAsync("window.localStorageFunctions.saveValue", "gh_repo", _githubRepo);
        await JSRuntime.InvokeVoidAsync("window.localStorageFunctions.saveValue", "gh_token", _githubToken);
    }

    private async Task LoadCredentials()
    {
        try
        {
            _githubUser = await JSRuntime.InvokeAsync<string?>("window.localStorageFunctions.getValue", "gh_user") ?? "Ledz3p";
            _githubRepo = await JSRuntime.InvokeAsync<string?>("window.localStorageFunctions.getValue", "gh_repo") ?? "ledz3p.github.io";
            _githubToken = await JSRuntime.InvokeAsync<string?>("window.localStorageFunctions.getValue", "gh_token") ?? "";
        }
        catch { }
    }

    private async Task SaveTokenConfiguration()
    {
        await SaveCredentials();
        _showTokenModal = false;
        await PullStateFromGitHub();
    }

    // ================= GITHUB BACKGROUND SYNC ENGINE =================
    private async Task PullStateFromGitHub()
    {
        if (string.IsNullOrWhiteSpace(_githubToken)) return;

        _isSyncing = true;
        _syncFailed = false;
        _syncStatus = "Syncing with cloud...";
        StateHasChanged();

        try
        {
            var requestUrl = $"https://api.github.com/repos/{_githubUser}/{_githubRepo}/contents/inventory.json";
            var request = new HttpRequestMessage(HttpMethod.Get, requestUrl);
            request.Headers.UserAgent.Add(new ProductInfoHeaderValue("YarnPWA", "1.0"));
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _githubToken);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(content);
                var root = doc.RootElement;

                _currentSha = root.GetProperty("sha").GetString() ?? "";
                var base64Data = root.GetProperty("content").GetString()?.Replace("\n", "").Replace("\r", "") ?? "";
                var jsonBytes = Convert.FromBase64String(base64Data);
                var cloudItems = JsonSerializer.Deserialize<List<YarnItem>>(jsonBytes);

                if (cloudItems != null)
                {
                    _items = cloudItems;
                    await SaveStateToStorage();
                    _syncStatus = "Cloud Synced";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _syncStatus = "Cloud Init Ready"; // File doesn't exist in repo yet
            }
            else
            {
                _syncFailed = true;
                _syncStatus = "Sync Failed Connection";
            }
        }
        catch
        {
            _syncFailed = true;
            _syncStatus = "Cloud Offline";
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task PushStateToGitHub()
    {
        if (string.IsNullOrWhiteSpace(_githubToken)) return;

        _isSyncing = true;
        _syncStatus = "Saving changes...";
        StateHasChanged();

        try
        {
            var requestUrl = $"https://api.github.com/repos/{_githubUser}/{_githubRepo}/contents/inventory.json";

            // Re-fetch SHA metadata to minimize split-universe concurrency conflicts
            var getRequest = new HttpRequestMessage(HttpMethod.Get, requestUrl);
            getRequest.Headers.UserAgent.Add(new ProductInfoHeaderValue("YarnPWA", "1.0"));
            getRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _githubToken);
            var getResponse = await Http.SendAsync(getRequest);
            if (getResponse.IsSuccessStatusCode)
            {
                using var doc = JsonDocument.Parse(await getResponse.Content.ReadAsStringAsync());
                _currentSha = doc.RootElement.GetProperty("sha").GetString() ?? "";
            }

            var rawJson = JsonSerializer.Serialize(_items, new JsonSerializerOptions { WriteIndented = true });
            var plainTextBytes = System.Text.Encoding.UTF8.GetBytes(rawJson);
            var base64Json = Convert.ToBase64String(plainTextBytes);

            var payload = new
            {
                message = "Automated Inventory State Sync Update via Mobile Device PWA",
                content = base64Json,
                sha = string.IsNullOrWhiteSpace(_currentSha) ? null : _currentSha
            };

            var putRequest = new HttpRequestMessage(HttpMethod.Put, requestUrl)
            {
                Content = new StringContent(JsonSerializer.Serialize(payload), System.Text.Encoding.UTF8, "application/json")
            };
            putRequest.Headers.UserAgent.Add(new ProductInfoHeaderValue("YarnPWA", "1.0"));
            putRequest.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _githubToken);

            var putResponse = await Http.SendAsync(putRequest);
            if (putResponse.IsSuccessStatusCode)
            {
                using var putDoc = JsonDocument.Parse(await putResponse.Content.ReadAsStringAsync());
                _currentSha = putDoc.RootElement.GetProperty("content").GetProperty("sha").GetString() ?? "";
                _syncFailed = false;
                _syncStatus = "Cloud Synced";
            }
            else
            {
                _syncFailed = true;
                _syncStatus = "Write Fault Check Auth";
            }
        }
        catch
        {
            _syncFailed = true;
            _syncStatus = "Cloud Target Unreachable";
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task HandleExcelImport(InputFileChangeEventArgs e)
    {
        try
        {
            CaptureSnapshot();
            using var memoryStream = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024).CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var importedList = new List<YarnItem>();

            var activeRows = memoryStream.Query(sheetName: "Yarn", useHeaderRow: true).ToList();
            foreach (IDictionary<string, object> row in activeRows)
            {
                string brand = row.ContainsKey("Brand") ? row["Brand"]?.ToString() ?? "" : "";
                string type = row.ContainsKey("Type") ? row["Type"]?.ToString() ?? "" : "";
                double.TryParse(row.ContainsKey("In stock #") ? row["In stock #"]?.ToString() : "0", out double stock);
                double.TryParse(row.ContainsKey("In project bag #") ? row["In project bag #"]?.ToString() : "0", out double bag);

                if (!string.IsNullOrWhiteSpace(type))
                {
                    importedList.Add(new YarnItem
                    {
                        Brand = string.IsNullOrWhiteSpace(brand) ? "Unknown Brand" : brand.Trim(),
                        Title = type.Trim(),
                        InStock = (int)Math.Floor(stock),
                        InBag = (int)Math.Floor(bag),
                        IsDiscontinued = false
                    });
                }
            }

            memoryStream.Position = 0;
            var discRows = memoryStream.Query(sheetName: "Discontinued Yarn", useHeaderRow: true).ToList();
            foreach (IDictionary<string, object> row in discRows)
            {
                string brand = row.ContainsKey("Brand") ? row["Brand"]?.ToString() ?? "" : "";
                string type = row.ContainsKey("Type") ? row["Type"]?.ToString() ?? "" : "";
                double.TryParse(row.ContainsKey("# of bags") ? row["# of bags"]?.ToString() : "0", out double bagsCount);
                double.TryParse(row.ContainsKey("Singles") ? row["Singles"]?.ToString() : "0", out double singlesCount);

                if (!string.IsNullOrWhiteSpace(type))
                {
                    importedList.Add(new YarnItem
                    {
                        Brand = string.IsNullOrWhiteSpace(brand) ? "Discontinued Brand" : brand.Trim(),
                        Title = type.Trim(),
                        InStock = (int)Math.Floor(singlesCount),
                        InBag = (int)Math.Floor(bagsCount),
                        IsDiscontinued = true
                    });
                }
            }

            if (importedList.Any())
            {
                _items = importedList;
                await SaveAndSync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Excel Import Pipeline Fault: {ex.Message}");
        }
    }
}